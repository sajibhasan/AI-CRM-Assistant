    {
      "parameters": {
        "options": {
          "systemMessage": "You are an AI CRM Assistant.\n\nExtract business information from the user's message.\n\nReturn ONLY valid JSON.\n\n{\n  \"name\": \"\",\n  \"email\": \"\",\n  \"company\": \"\",\n  \"country\": \"\",\n  \"role\": \"\",\n  \"budget\": 0,\n  \"urgency\": \"\",\n  \"industry\": \"\",\n  \"notes\": \"\",\n  \"reason\": \"\",\n  \"next_action\": \"\"\n}\n\nRules:\n\nBudget Rules:\n\n- Return budget as a NUMBER only.\n- Do not include currency.\n- Do not include USD, BDT, $, commas or text.\n\nExamples:\n\n25000 USD -> 25000\n$15,000 -> 15000\nBDT 500000 -> 500000\n\nIf no budget is mentioned, return 0.\n- Return only raw JSON.\n- Never use markdown.\nAlways return every field.\n\nIf a value is unknown, return:\n- \"\" for text fields\n- 0 for numeric fields\n\nNever omit any field.\n\n---\n\n\n```text\nIMPORTANT RULES\n\n- Return ONLY valid JSON.\n- Never use markdown.\n- Never use ```json.\n- Never explain your answer.\n- Never write any text before or after the JSON.\n- If a field is missing, return:\n  - \"\" for text fields\n  - 0 for numeric fields\n- Always return every field."
        }
      },
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 3.1,
      "position": [
        -592,
        -48
      ],
      "id": "c4c4ccbc-5ba5-4acd-ba62-60280d396bc0",
      "name": "AI Lead Extractor"
    },
    {
      "parameters": {
        "jsCode": "let output = String($json.output || \"\").trim();\n\n// Remove any markdown fences\noutput = output\n  .replace(/```json/gi, \"\")\n  .replace(/```/g, \"\")\n  .trim();\n\nlet lead;\n\ntry {\n  lead = JSON.parse(output);\n} catch (error) {\n  return [{\n    json: {\n      is_valid: false,\n      validation_errors: [\"AI returned invalid JSON\"],\n      raw_output: output\n    }\n  }];\n}\n\n// ===========================\n// Business Scoring Engine\n// ===========================\n\nconst CONFIG = {\n  hotThreshold: 80,\n  warmThreshold: 50,\n\n  decisionMakerScore: 30,\n  budget20kScore: 30,\n  budget10kScore: 20,\n  budget5kScore: 10,\n\n  urgencyHighScore: 20,\n  urgencyMediumScore: 10,\n\n  companyScore: 10,\n  emailScore: 10,\n};\n\nlet score = 0;\n\n// Role\nconst role = (lead.role || \"\").toLowerCase();\n\nif (\n  role.includes(\"ceo\") ||\n  role.includes(\"cto\") ||\n  role.includes(\"founder\") ||\n  role.includes(\"owner\")\n) {\n  score += CONFIG.decisionMakerScore;\n}\n\n// Budget\nconst budget = parseFloat(\n  String(lead.budget || \"0\").replace(/[^0-9.]/g, \"\")\n);\n\nif (budget >= 20000) {\n  score += CONFIG.budget20kScore;\n} else if (budget >= 10000) {\n  score += CONFIG.budget10kScore;\n} else if (budget >= 5000) {\n  score += CONFIG.budget5kScore;\n}\n\n// Urgency\nconst urgency = (lead.urgency || \"\").toLowerCase();\n\nif (urgency === \"high\") {\n  score += CONFIG.urgencyHighScore;\n} else if (urgency === \"medium\") {\n  score += CONFIG.urgencyMediumScore;\n}\n\n// Company\nif (lead.company && lead.company.trim() !== \"\") {\n  score += CONFIG.companyScore;\n}\n\n// Email\nif (\n  lead.email &&\n  /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(lead.email)\n) {\n  score += CONFIG.emailScore;\n}\n\n\n// Save Score\nlead.lead_score = score;\n\n// Priority\nif (score >= CONFIG.hotThreshold) {\n  lead.priority = \"Hot\";\n} else if (score >= CONFIG.warmThreshold) {\n  lead.priority = \"Warm\";\n} else {\n  lead.priority = \"Cold\";\n}\n\nlead.is_valid = true;\nlead.validation_errors = [];\n\n// Name validation\nif (!lead.name || lead.name.trim() === \"\") {\n  lead.is_valid = false;\n  lead.validation_errors.push(\"Missing name\");\n}\n\n// Email validation\nconst emailRegex = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/;\n\nif (!lead.email || !emailRegex.test(lead.email)) {\n  lead.is_valid = false;\n  lead.validation_errors.push(\"Invalid email\");\n}\n\nreturn [\n  {\n    json: lead\n  }\n];"
      },
