    {
      "parameters": {
        "sendTo": "sajib001@gmail.com",
        "subject": "=🚨 {{$json.priority}} Lead | {{$json.company}} | Score {{$json.lead_score}}\n{{\n$json.priority === \"Hot\"\n? \"🔥\"\n: $json.priority === \"Warm\"\n? \"🟡\"\n: \"⚪\"\n}}",
        "message": "=<h2>🚀 New {{ $json.priority }} Lead</h2>\n\n<hr>\n\n<table style=\"border-collapse: collapse; width: 100%;\">\n<tr>\n<td><b>Name</b></td>\n<td>{{ $json.name }}</td>\n</tr>\n\n<tr>\n<td><b>Company</b></td>\n<td>{{ $json.company }}</td>\n</tr>\n\n<tr>\n<td><b>Email</b></td>\n<td>{{ $json.email }}</td>\n</tr>\n\n<tr>\n<td><b>Country</b></td>\n<td>{{ $json.country }}</td>\n</tr>\n\n<tr>\n<td><b>Role</b></td>\n<td>{{ $json.role }}</td>\n</tr>\n\n<tr>\n<td><b>Budget</b></td>\n<td>{{ $json.budget }}</td>\n</tr>\n\n<tr>\n<td><b>Lead Score</b></td>\n<td>{{ $json.lead_score }}/100</td>\n</tr>\n\n<tr>\n<td><b>Priority</b></td>\n<td><b>{{ $json.priority }}</b></td>\n</tr>\n</table>\n\n<hr>\n\n<p>This notification was automatically generated by the AI CRM Assistant.</p>",
